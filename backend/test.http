@baseUrl = http://127.0.0.1:8000

### ─────────────────────────────────────────
### AUTH
### ─────────────────────────────────────────

### Sign up a new user
POST {{baseUrl}}/auth/signup
Content-Type: application/json

{
  "email": "alice@example.com",
  "password": "secret123",
  "role": "admin"
}

###

### Sign up a second user (for task assignment)
POST {{baseUrl}}/auth/signup
Content-Type: application/json

{
  "email": "bob@example.com",
  "password": "secret123",
  "role": "member"
}

###

### Login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "alice@example.com",
  "password": "secret123",
  "role": "admin"
}

###

### Login – wrong password (expect 401)
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "alice@example.com",
  "password": "wrongpassword",
  "role": "admin"
}

###

### Login – unknown user (expect 404)
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "ghost@example.com",
  "password": "secret123",
  "role": "member"
}

### ─────────────────────────────────────────
### PROJECTS
### ─────────────────────────────────────────

### Create a project
POST {{baseUrl}}/projects/
Content-Type: application/json

{
  "name": "Team Task Manager"
}

###

### Create another project
POST {{baseUrl}}/projects/
Content-Type: application/json

{
  "name": "Marketing Campaign"
}

### ─────────────────────────────────────────
### TASKS
### ─────────────────────────────────────────

### Get all tasks
GET {{baseUrl}}/tasks/

###

### Create a task
POST {{baseUrl}}/tasks/
Content-Type: application/json

{
  "title": "Design database schema",
  "project_id": 1,
  "assigned_to": 1,
  "due_date": "2026-05-10T12:00:00"
}

###

### Create an overdue task (due in the past)
POST {{baseUrl}}/tasks/
Content-Type: application/json

{
  "title": "Write unit tests",
  "project_id": 1,
  "assigned_to": 2,
  "due_date": "2026-04-01T09:00:00"
}

###

### Get all tasks (after creation)
GET {{baseUrl}}/tasks/

### ─────────────────────────────────────────
### DASHBOARD
### ─────────────────────────────────────────

### Get dashboard summary (total tasks + overdue count)
GET {{baseUrl}}/dashboard/
